<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OfficeTool.Ui.ViewModels"
             x:Class="OfficeTool.Ui.Views.BackupConfigsView"
             x:DataType="vm:BackupConfigsViewModel">
    
    <ScrollViewer>
        <StackPanel Margin="20" Spacing="15">
            
            <Button Content="← Back to menu" 
                    Command="{Binding GoBackCommand}" 
                    Background="Transparent" 
                    Foreground="LightGray"
                    Cursor="Hand"/>
                    
            <TextBlock Text="ZIP Configs Modifier" 
                       FontSize="22" 
                       FontWeight="Bold" />

            <Border Background="#c0c0c0" 
                    CornerRadius="8" 
                    Padding="15">
                <StackPanel Spacing="10">
                    
                    <TextBlock Text="1. Select base file (config.zip):" 
                               FontWeight="SemiBold"/>
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBox Text="{Binding BaseZipPath}" 
                                 IsReadOnly="True" Grid.Column="0" 
                                 Margin="0,0,10,0"/>
                        <Button Content="Browse..." 
                                Command="{Binding PickBaseZipCommand}" 
                                Grid.Column="1"/>
                    </Grid>
                    
                    <TextBlock Text="(IP address will be read automatically after selecting the file)" 
                               FontStyle="Italic" 
                               Foreground="Gray" 
                               FontSize="12" 
                               Margin="0,-5,0,5"/>

                    <TextBlock Text="2. Destination directory:" 
                               Margin="0,5,0,0" 
                               FontWeight="SemiBold"/>
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBox Text="{Binding DestinationFolderPath}" 
                                 IsReadOnly="True" 
                                 Grid.Column="0" 
                                 Margin="0,0,10,0"/>
                        <Button Content="Browse..." 
                                Command="{Binding PickDestinationFolderCommand}" 
                                Grid.Column="1"/>
                    </Grid>

                    <TextBlock Text="3. Set amount of new files:" 
                               Margin="0,15,0,0" 
                               FontWeight="SemiBold"/>
                    
                    <StackPanel Spacing="15" 
                                Margin="10,0,0,0">
                        
                        <RadioButton Content="Amount of new files (generating upwards):" 
                                     IsChecked="{Binding IsAmountMode}" 
                                     GroupName="GenerationMethod"/>
                                     
                        <NumericUpDown Value="{Binding AmountOfFiles}" 
                                       IsEnabled="{Binding IsAmountMode}"
                                       FormatString="0" 
                                       Minimum="1" Maximum="10000" 
                                       HorizontalAlignment="Left" 
                                       Width="150" 
                                       Margin="25,0,0,0"/>
                         
                        <RadioButton Content="Generate for range:" 
                                     IsChecked="{Binding !IsAmountMode}" 
                                     GroupName="GenerationMethod"/>
                                     
                        <Grid RowDefinitions="Auto, Auto" 
                              ColumnDefinitions="Auto, Auto" 
                              Margin="25,0,0,0" 
                              IsEnabled="{Binding !IsAmountMode}">
                            
                            <TextBlock Grid.Row="0" 
                                       Grid.Column="0" 
                                       Text="From:" 
                                       VerticalAlignment="Center" 
                                       Margin="0,0,15,10" FontWeight="SemiBold"/>
                            <StackPanel Grid.Row="0" 
                                        Grid.Column="1" 
                                        Orientation="Horizontal" 
                                        Margin="0,0,0,10">
                                <NumericUpDown Value="{Binding StartOctet1}" 
                                               Minimum="0" Maximum="255" 
                                               FormatString="0" 
                                               ShowButtonSpinner="False" 
                                               Width="55"/>
                                <TextBlock Text="." 
                                           VerticalAlignment="Bottom" 
                                           FontSize="20" 
                                           Margin="2,0,2,5"/>
                                <NumericUpDown Value="{Binding StartOctet2}" 
                                               Minimum="0" Maximum="255" 
                                               FormatString="0" 
                                               ShowButtonSpinner="False" 
                                               Width="55"/>
                                <TextBlock Text="." 
                                           VerticalAlignment="Bottom" 
                                           FontSize="20" Margin="2,0,2,5"/>
                                <NumericUpDown Value="{Binding StartOctet3}" 
                                               Minimum="0" Maximum="255" 
                                               FormatString="0" 
                                               ShowButtonSpinner="False" 
                                               Width="55"/>
                                <TextBlock Text="." 
                                           VerticalAlignment="Bottom" 
                                           FontSize="20" Margin="2,0,2,5"/>
                                <NumericUpDown Value="{Binding StartOctet4}" 
                                               Minimum="0"
                                               Maximum="255" 
                                               FormatString="0" 
                                               ShowButtonSpinner="False"
                                               Width="55"/>
                             </StackPanel>

                            <TextBlock Grid.Row="1" 
                                       Grid.Column="0" 
                                       Text="To:" 
                                       VerticalAlignment="Center" 
                                       Margin="0,0,15,0" 
                                       FontWeight="SemiBold"/>
                            <StackPanel Grid.Row="1" 
                                        Grid.Column="1" 
                                        Orientation="Horizontal">
                                <NumericUpDown Value="{Binding EndOctet1}" 
                                               Minimum="0" Maximum="255" 
                                               FormatString="0" 
                                               ShowButtonSpinner="False" 
                                               Width="55"/>
                                <TextBlock Text="." 
                                           VerticalAlignment="Bottom" 
                                           FontSize="20" 
                                           Margin="2,0,2,5"/>
                                <NumericUpDown Value="{Binding EndOctet2}" 
                                               Minimum="0" 
                                               Maximum="255" 
                                               FormatString="0" 
                                               ShowButtonSpinner="False" 
                                               Width="55"/>
                                <TextBlock Text="." 
                                           VerticalAlignment="Bottom" 
                                           FontSize="20" 
                                           Margin="2,0,2,5"/>
                                <NumericUpDown Value="{Binding EndOctet3}" 
                                               Minimum="0" 
                                               Maximum="255" 
                                               FormatString="0" 
                                               ShowButtonSpinner="False" 
                                               Width="55"/>
                                <TextBlock Text="." 
                                           VerticalAlignment="Bottom" 
                                           FontSize="20" 
                                           Margin="2,0,2,5"/>
                                <NumericUpDown Value="{Binding EndOctet4}" 
                                               Minimum="0" 
                                               Maximum="255" 
                                               FormatString="0" 
                                               ShowButtonSpinner="False" 
                                               Width="55"/>
                            </StackPanel>

                        </Grid>
                    </StackPanel>
                </StackPanel>
             </Border>

<StackPanel Orientation="Horizontal" 
            HorizontalAlignment="Right" 
            Spacing="15" 
            Margin="0,10,0,0" 
            IsEnabled="{Binding !IsGenerating}">
                
                <StackPanel VerticalAlignment="Center" 
                             HorizontalAlignment="Right">
                    <TextBlock Text="{Binding GenerationStatus}" 
                               FontSize="12" 
                               FontStyle="Italic" 
                               Foreground="Yellow" 
                               HorizontalAlignment="Right" 
                               Margin="0,0,0,5"/>
                    
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Right">
                         <TextBlock Text="To generate: " 
                                   FontSize="14" 
                                   Foreground="Gray" 
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CalculatedTotalFiles}" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="LightSkyBlue"/>
                        <TextBlock Text=" files" 
                                   FontSize="18" 
                                   FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>

                <Button Content="GENERATE" 
                        Command="{Binding GenerateCommand}" 
                        Padding="30,15"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#0078d7"
                        Foreground="White"
                        Cursor="Hand"/>
            </StackPanel>
                  
        </StackPanel>
    </ScrollViewer>
</UserControl>